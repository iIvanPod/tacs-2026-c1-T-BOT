TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
GEMINI_API_KEY=
# URL pública por la que Telegram alcanza al bot (webhook). En local, la del túnel (ngrok/cloudflared).
# En Render no hace falta: se toma de RENDER_EXTERNAL_URL.
WEBHOOK_URL=
# Secret token del webhook (solo A-Z a-z 0-9 _ -). Opcional pero recomendado.
WEBHOOK_SECRET=
